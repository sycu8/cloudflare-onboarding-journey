# Copy to wrangler.toml and fill in your Cloudflare account resource IDs.
# Do NOT commit wrangler.toml if it contains production-only bindings you want private.

name = "cloudflare-starter-hub"
compatibility_date = "2026-06-02"
pages_build_output_dir = "dist"

[[d1_databases]]
binding = "DB"
database_name = "cloudflare-starter-hub-db"
database_id = "REPLACE_WITH_YOUR_D1_DATABASE_ID"

[[kv_namespaces]]
binding = "SITE_CONFIG"
id = "REPLACE_WITH_YOUR_KV_NAMESPACE_ID"

[[r2_buckets]]
binding = "RESOURCES_BUCKET"
bucket_name = "cloudflare-starter-hub-resources"

[ai]
binding = "AI"

# Cloudflare AI Search — semantic search over hub content (optional)
# Create instance in dashboard: AI > AI Search > Website data source (sitemap-index.xml)
[[ai_search]]
binding = "HUB_SEARCH"
instance_name = "cloudflare-starter-hub"

# Alternative: namespace binding + runtime instance id
# [[ai_search_namespaces]]
# binding = "AI_SEARCH"
# namespace = "default"

# Workshop email — Cloudflare Email Service REST API (no send_email binding on Pages)
[vars]
CLOUDFLARE_ACCOUNT_ID = "REPLACE_WITH_ACCOUNT_ID"
AI_SEARCH_INSTANCE = "cloudflare-starter-hub"

# Pages secret: CLOUDFLARE_EMAIL_API_TOKEN (Email Sending permission)
# Optional vars: WORKSHOP_EMAIL_FROM, PUBLIC_SITE_URL
# Domain orangecloud.vn must be onboarded in Email Service (SPF/DKIM)
