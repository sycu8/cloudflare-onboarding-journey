---
import type { RoleRoadmap } from '../../types/roadmap';

type Props = { roadmap: RoleRoadmap };

const { roadmap } = Astro.props;

const levelLabels = {
  zero: { vi: 'Từ con số 0', en: 'From zero' },
  basic: { vi: 'Cơ bản', en: 'Basic' },
  technical: { vi: 'Kỹ thuật', en: 'Technical' },
};

const trackLabels = {
  'application-services': { vi: 'Application Services', en: 'Application Services' },
  'developer-platform': { vi: 'Developer Platform', en: 'Developer Platform' },
  'cloudflare-one': { vi: 'Cloudflare One', en: 'Cloudflare One' },
  mixed: { vi: 'Hỗn hợp', en: 'Mixed' },
};
---

<article class="card flex flex-col">
  <h2 class="text-xl font-semibold">
    <span class="lang-vi">{roadmap.roleNameVi}</span>
    <span class="lang-en">{roadmap.roleNameEn ?? roadmap.roleNameVi}</span>
  </h2>
  <p class="text-muted mt-2 flex-1 text-sm leading-relaxed">
    <span class="lang-vi">{roadmap.descriptionVi}</span>
    <span class="lang-en">{roadmap.descriptionVi}</span>
  </p>

  <ul class="text-muted mt-3 space-y-1 text-xs">
    {roadmap.bestForVi.map((item) => (
      <li>• {item}</li>
    ))}
  </ul>

  <dl class="text-muted mt-4 grid gap-2 text-xs sm:grid-cols-2">
    <div>
      <dt class="font-medium text-[var(--cf-text)]">
        <span class="lang-vi">Thời lượng</span>
        <span class="lang-en">Duration</span>
      </dt>
      <dd>
        <span class="lang-vi">{roadmap.totalWeeks} tuần</span>
        <span class="lang-en">{roadmap.totalWeeks} weeks</span>
      </dd>
    </div>
    <div>
      <dt class="font-medium text-[var(--cf-text)]">
        <span class="lang-vi">Trình độ bắt đầu</span>
        <span class="lang-en">Starting level</span>
      </dt>
      <dd>
        <span class="lang-vi">{levelLabels[roadmap.startingLevel].vi}</span>
        <span class="lang-en">{levelLabels[roadmap.startingLevel].en}</span>
      </dd>
    </div>
    <div class="sm:col-span-2">
      <dt class="font-medium text-[var(--cf-text)]">
        <span class="lang-vi">Track chính</span>
        <span class="lang-en">Primary track</span>
      </dt>
      <dd>
        <span class="lang-vi">{trackLabels[roadmap.primaryTrack].vi}</span>
        <span class="lang-en">{trackLabels[roadmap.primaryTrack].en}</span>
      </dd>
    </div>
  </dl>

  <p class="text-muted mt-4 text-sm">
    <span class="font-medium text-[var(--cf-text)] lang-vi">Kết quả: </span>
    <span class="font-medium text-[var(--cf-text)] lang-en">Outcome: </span>
    {roadmap.finalOutcomeVi}
  </p>

  <a class="btn btn-primary mt-4 w-full justify-center" href={`/roadmaps/${roadmap.roleId}/`}>
    <span class="lang-vi">Xem roadmap</span>
    <span class="lang-en">View roadmap</span>
  </a>
</article>
