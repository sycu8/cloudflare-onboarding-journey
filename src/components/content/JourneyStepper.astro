---
import LangText from '../ui/LangText.astro';

type Step = { vi: string; en: string };
type Props = { steps: Step[] };
const { steps } = Astro.props;
---

<ol class="card space-y-3">
  {steps.map((s, idx) => (
    <li class="flex gap-3">
      <div class="badge badge-accent mt-0.5 flex h-6 w-6 flex-none items-center justify-center rounded-lg p-0 text-xs font-semibold">
        {idx + 1}
      </div>
      <LangText as="p" class="text-muted text-sm" text={s} />
    </li>
  ))}
</ol>

