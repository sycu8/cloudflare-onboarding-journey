---
import LangText from '../ui/LangText.astro';
import type { TrackModule } from '../../data/tracks';

type Props = {
  module: TrackModule;
};

const { module } = Astro.props;
---

<article class="card">
  <div class="flex flex-wrap items-center gap-2">
    {module.duration ? <span class="badge badge-accent"><LangText text={module.duration} /></span> : null}
    <span class="badge">
      <span class="lang-vi">{module.lessons.length} bài</span>
      <span class="lang-en">{module.lessons.length} lessons</span>
    </span>
  </div>

  <LangText as="h3" class="mt-3 text-lg font-semibold" text={module.title} />
  <LangText as="p" class="text-muted mt-2 text-sm" text={module.description} />

  <ol class="mt-4 space-y-4">
    {module.lessons.map((lesson, li) => (
      <li class="rounded-xl border border-[var(--cf-border)] bg-[var(--cf-bg-elevated)]/50 p-4">
        <div class="flex gap-3">
          <span class="badge badge-accent mt-0.5 shrink-0">{li + 1}</span>
          <div class="min-w-0 flex-1">
            <LangText as="h4" class="font-medium" text={lesson.title} />
            <LangText as="p" class="text-muted mt-2 text-sm leading-relaxed" text={lesson.body} />
            {lesson.tip ? (
              <p class="mt-2 rounded-lg border border-[var(--cf-border)] bg-[var(--cf-surface)] px-3 py-2 text-xs">
                <span class="font-medium text-[var(--cf-accent)]">
                  <span class="lang-vi">Mẹo: </span>
                  <span class="lang-en">Tip: </span>
                </span>
                <span class="lang-vi">{lesson.tip.vi}</span>
                <span class="lang-en">{lesson.tip.en}</span>
              </p>
            ) : null}
            {lesson.hubLink ? (
              <a class="link mt-2 inline-block text-sm" href={lesson.hubLink}>
                <span class="lang-vi">Đọc thêm trong hub →</span>
                <span class="lang-en">Read more in the hub →</span>
              </a>
            ) : null}
          </div>
        </div>
      </li>
    ))}
  </ol>
</article>
