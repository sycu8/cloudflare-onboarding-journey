---
import LangText from '../ui/LangText.astro';
import type { ReferenceArchitectureItem } from '../../data/referenceArchitecture';
import { referenceDocTypeLabels } from '../../data/referenceArchitecture';
import { getDiagramForRefArchItem } from '../../data/referenceDiagrams';

type Props = { item: ReferenceArchitectureItem };
const { item } = Astro.props;
const typeLabel = referenceDocTypeLabels[item.docType];
const diagram = getDiagramForRefArchItem(item.slug);
---

<article class="card flex h-full flex-col overflow-hidden p-0">
  {diagram ? (
    <a
      href={diagram.pageUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="block overflow-hidden border-b border-[var(--cf-border)] bg-[var(--cf-bg-elevated)]"
    >
      <img
        src={diagram.primaryImageUrl}
        alt={diagram.images[0]?.alt.en ?? diagram.title.en}
        loading="lazy"
        decoding="async"
        class="h-36 w-full object-contain object-center p-2"
      />
    </a>
  ) : null}
  <div class="flex flex-1 flex-col p-6">
  <div class="flex flex-wrap items-center gap-2">
    <span class="badge badge-accent"><LangText text={typeLabel} /></span>
    {item.featured ? (
      <span class="badge">
        <span class="lang-vi">Nổi bật</span>
        <span class="lang-en">Featured</span>
      </span>
    ) : null}
    <span class="badge">
      <span class="lang-vi">Lộ trình:</span>
      <span class="lang-en">Track:</span>
      {' '}
      {item.relatedTrack === 'application-services'
        ? 'Application Services'
        : item.relatedTrack === 'developer-platform'
          ? 'Developer Platform'
          : item.relatedTrack === 'cloudflare-one'
            ? 'Cloudflare One'
            : 'Cross-cutting'}
    </span>
  </div>
  <LangText as="h3" class="mt-3 text-lg font-semibold leading-snug" text={item.title} />
  <LangText as="p" class="text-muted mt-2 flex-1 text-sm leading-relaxed" text={item.summary} />
  <div class="mt-4 flex flex-col gap-2 sm:flex-row">
    <a
      class="btn btn-secondary flex-1 justify-center"
      href={item.officialPath}
      target="_blank"
      rel="noopener noreferrer"
    >
      <LangText text={{ vi: 'Đọc trên Cloudflare', en: 'Read on Cloudflare' }} />
      <span aria-hidden="true">↗</span>
    </a>
    {item.relatedTrack !== 'cross-cutting' ? (
      <a class="btn btn-ghost flex-1 justify-center" href={`/tracks/${item.relatedTrack}`}>
        <LangText text={{ vi: 'Xem lộ trình', en: 'View track' }} />
      </a>
    ) : null}
  </div>
  </div>
</article>
