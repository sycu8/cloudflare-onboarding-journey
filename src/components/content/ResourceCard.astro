---
import LangText from '../ui/LangText.astro';

type Props = {
  title: { vi: string; en: string };
  description: { vi: string; en: string };
  type: string;
  href: string;
  status: 'available' | 'coming-soon';
};

const { title, description, type, href, status } = Astro.props;
const external = href.startsWith('http');
---

<article class="card flex h-full flex-col">
  <div class="flex items-center justify-between gap-2">
    <span class="badge">{type}</span>
    {status === 'coming-soon' ? (
      <span class="badge badge-accent">
        <span class="lang-vi">Sắp có</span>
        <span class="lang-en">Coming soon</span>
      </span>
    ) : null}
  </div>
  <LangText as="h2" class="mt-3 text-lg font-semibold" text={title} />
  <LangText as="p" class="text-muted mt-2 flex-1 text-sm" text={description} />
  <div class="mt-4">
    {status === 'coming-soon' ? (
      <span class="btn btn-secondary w-full cursor-not-allowed opacity-60" aria-disabled="true">
        <LangText text={{ vi: 'Sắp có', en: 'Coming soon' }} />
      </span>
    ) : (
      <a class="btn btn-secondary w-full justify-between" href={href} target={external ? '_blank' : undefined} rel={external ? 'noopener noreferrer' : undefined}>
        <LangText text={{ vi: external ? 'Mở liên kết' : 'Mở', en: external ? 'Open link' : 'Open' }} />
        <span aria-hidden="true">{external ? '↗' : '→'}</span>
      </a>
    )}
  </div>
</article>
