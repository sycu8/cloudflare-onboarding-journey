---
import LangText from '../ui/LangText.astro';
import type { UseCase } from '../../data/useCases';
import { useCaseTrackLabels } from '../../data/useCases';

type Props = { useCase: UseCase; showTrack?: boolean };
const { useCase, showTrack = true } = Astro.props;
const trackLabel = useCaseTrackLabels[useCase.relatedTrack].title;
---

<article class="card flex h-full flex-col">
  {showTrack ? (
    <p class="text-muted mb-2 text-xs font-medium uppercase tracking-wide">
      <LangText text={trackLabel} />
    </p>
  ) : null}
  <LangText as="h3" class="text-lg font-semibold leading-snug" text={useCase.title} />
  <LangText as="p" class="text-muted mt-2 flex-1 text-sm leading-relaxed" text={useCase.problem} />
  <p class="mt-3 font-mono text-xs text-[var(--cf-accent)] opacity-90">
    <span class="lang-vi">{useCase.architecture.vi}</span>
    <span class="lang-en">{useCase.architecture.en}</span>
  </p>
  <div class="mt-4 flex flex-col gap-2">
    <a class="btn btn-secondary w-full justify-center" href={`/use-cases/${useCase.slug}/`}>
      <LangText text={{ vi: 'Đọc tình huống →', en: 'Read use case →' }} />
    </a>
    <a
      class="text-muted text-center text-xs hover:text-[var(--cf-accent)]"
      href={useCase.officialUrl}
      rel="noopener noreferrer"
      target="_blank"
    >
      <span class="lang-vi">Tài liệu Cloudflare →</span>
      <span class="lang-en">Official Cloudflare docs →</span>
    </a>
  </div>
</article>
