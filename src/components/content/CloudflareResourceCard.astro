---
import LangText from '../ui/LangText.astro';
import type { CloudflareResource } from '../../data/cloudflareResources';
import {
  cloudflareResourceContentTypeLabels,
  cloudflareResourceTrackLabels,
} from '../../data/cloudflareResources';

type Props = { resource: CloudflareResource; compact?: boolean };
const { resource, compact = false } = Astro.props;
const typeLabel = cloudflareResourceContentTypeLabels[resource.contentType];
const trackLabel = cloudflareResourceTrackLabels[resource.track];
---

<article class:list={['card flex h-full flex-col', compact ? 'p-4' : 'p-5']}>
  <div class="flex flex-wrap items-center gap-2">
    <span class="badge badge-accent text-xs"><LangText text={typeLabel} /></span>
    <span class="badge text-xs"><LangText text={trackLabel} /></span>
  </div>
  <h3 class:list={['mt-3 font-semibold leading-snug', compact ? 'text-sm' : 'text-base']}>
    {resource.title}
  </h3>
  <p class="text-muted mt-2 flex-1 text-xs break-all opacity-80">{resource.path}</p>
  <a
    class="btn btn-secondary mt-4 w-full justify-center text-sm"
    href={resource.url}
    target="_blank"
    rel="noopener noreferrer"
  >
    <LangText text={{ vi: 'Mở tutorial / guide ↗', en: 'Open tutorial / guide ↗' }} />
  </a>
</article>
