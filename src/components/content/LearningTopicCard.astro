---
import LangText from '../ui/LangText.astro';
import type { LearningTopic } from '../../data/learningCenter';

type Props = { topic: LearningTopic };
const { topic } = Astro.props;
---

<article class="card flex h-full flex-col">
  <div class="flex flex-wrap items-center gap-2">
    <span class="badge">{topic.category}</span>
    <span class="badge">
      <span class="lang-vi">Lộ trình:</span>
      <span class="lang-en">Track:</span>
      {' '}
      {topic.relatedTrack === 'application-services'
        ? 'Application Services'
        : topic.relatedTrack === 'developer-platform'
          ? 'Developer Platform'
          : 'Cloudflare One'}
    </span>
  </div>
  <LangText as="h3" class="mt-3 text-lg font-semibold" text={topic.title} />
  <LangText as="p" class="text-muted mt-2 flex-1 text-sm" text={topic.summary} />
  <div class="mt-4 flex flex-col gap-2 sm:flex-row">
    <a
      class="btn btn-secondary flex-1 justify-center"
      href={topic.officialPath}
      target="_blank"
      rel="noopener noreferrer"
    >
      <LangText text={{ vi: 'Đọc trên Cloudflare Learning', en: 'Read on Cloudflare Learning' }} />
      <span aria-hidden="true">↗</span>
    </a>
    <a
      class="btn btn-ghost flex-1 justify-center"
      href={`/tracks/${topic.relatedTrack}`}
    >
      <LangText text={{ vi: 'Xem lộ trình', en: 'View track' }} />
    </a>
  </div>
</article>
