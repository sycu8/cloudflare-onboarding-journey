---
import LangText from '../ui/LangText.astro';
import UseCaseCard from './UseCaseCard.astro';
import {
  useCaseTrackLabels,
  useCaseTrackOrder,
  getUseCasesByTrack,
  useCases,
  useCaseHubCategoryOrder,
  useCaseHubCategoryMeta,
  getUseCasesByHubCategory,
  OFFICIAL_USE_CASES_HUB,
} from '../../data/useCases';
---

<section class="mb-6 grid gap-3 sm:grid-cols-3">
  {
    useCaseTrackOrder.map((trackKey) => {
      const meta = useCaseTrackLabels[trackKey];
      const count = getUseCasesByTrack(trackKey).length;
      return (
        <a class="card block transition hover:border-[var(--cf-accent)]" href={`/use-cases/${trackKey}/`}>
          <LangText as="h2" class="text-base font-semibold" text={meta.title} />
          <LangText as="p" class="text-muted mt-1 text-xs" text={meta.headline} />
          <p class="text-muted mt-2 text-xs">
            <span class="lang-vi">{count} tình huống · Lộ trình học →</span>
            <span class="lang-en">{count} scenarios · Learning track →</span>
          </p>
        </a>
      );
    })
  }
</section>

{
  useCaseHubCategoryOrder.map((categoryKey) => {
    const meta = useCaseHubCategoryMeta[categoryKey];
    const cases = getUseCasesByHubCategory(categoryKey);
    return (
      <section id={categoryKey} class="mb-10 scroll-mt-24">
        <div class="mb-4 border-b border-[var(--cf-border)] pb-4">
          <LangText as="h2" class="text-xl font-semibold" text={meta.title} />
          <LangText as="p" class="text-muted mt-1 max-w-3xl text-sm" text={meta.headline} />
        </div>
        <div class="grid gap-4 md:grid-cols-2">
          {cases.map((uc) => (
            <UseCaseCard useCase={uc} showTrack />
          ))}
        </div>
      </section>
    );
  })
}

<p class="text-muted text-center text-xs">
  <span class="lang-vi">
    {useCases.length} tình huống — nhóm theo{' '}
    <a class="link" href={OFFICIAL_USE_CASES_HUB} rel="noopener noreferrer" target="_blank">
      Cloudflare Use cases
    </a>
    , mỗi kịch bản gắn lộ trình học nội bộ.
  </span>
  <span class="lang-en">
    {useCases.length} scenarios — grouped like{' '}
    <a class="link" href={OFFICIAL_USE_CASES_HUB} rel="noopener noreferrer" target="_blank">
      Cloudflare Use cases
    </a>
    , each mapped to a learning track.
  </span>
</p>
