---
import LangText from '../ui/LangText.astro';
import CloudflareLogo from './CloudflareLogo.astro';
import LanguageSwitcher from '../ui/LanguageSwitcher';
import ThemeToggle from '../ui/ThemeToggle';
import MobileMenu from '../interactive/MobileMenu';
import SiteSearch from '../interactive/SiteSearch';
import { primaryNavItems, mobileNavPrimary, mobileNavMore } from '../../data/navigation';

const currentPath = Astro.url.pathname;
---

<header class="site-header sticky top-0 z-50">
  <div class="container flex h-14 items-center justify-between gap-2 sm:h-16 sm:gap-3">
    <a href="/" class="flex min-w-0 shrink items-center font-semibold tracking-tight" aria-label="Cloudflare Starter Hub — Home">
      <CloudflareLogo />
    </a>

    <nav class="hidden items-center gap-0.5 md:flex" aria-label="Primary">
      {primaryNavItems.map((item) => {
        const normalized = item.href.replace(/\/$/, '') || '/';
        const pathNorm = currentPath.replace(/\/$/, '') || '/';
        const active =
          pathNorm === normalized ||
          (normalized !== '/' && normalized !== '/use-cases' && pathNorm.startsWith(normalized)) ||
          (normalized === '/use-cases' && pathNorm.startsWith('/use-cases'));
        return (
          <a
            href={item.href}
            class:list={['btn btn-ghost px-2.5 py-2 text-sm xl:px-3', active ? 'nav-link-active' : '']}
            aria-current={active ? 'page' : undefined}
          >
            <LangText text={item.label} />
          </a>
        );
      })}
    </nav>

    <div class="flex shrink-0 items-center gap-0">
      <SiteSearch client:load />
      <MobileMenu client:load primary={[...mobileNavPrimary]} more={[...mobileNavMore]} />
      <ThemeToggle client:load />
      <LanguageSwitcher client:load />
      <a href="/choose-your-path" class="btn btn-primary ml-1 hidden px-3 py-2 text-sm md:inline-flex">
        <LangText text={{ vi: 'Chọn lộ trình', en: 'Choose path' }} />
      </a>
    </div>
  </div>
</header>
