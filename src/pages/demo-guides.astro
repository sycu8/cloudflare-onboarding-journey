---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/chrome/Breadcrumbs.astro';
import LangText from '../components/ui/LangText.astro';
import DemoVignetteList from '../components/interactive/DemoVignetteList';
import {
  applicationSecurityDemos,
  cloudflareOneDemos,
  platformDemoVignettes,
  demoScriptsIntro,
  demoScriptsDisclaimer,
} from '../data/demoScripts';
---

<BaseLayout
  title={{
    vi: 'Script demo dashboard — Application Security & Cloudflare One',
    en: 'Dashboard demo scripts — Application Security & Cloudflare One',
  }}
  description={{
    vi: 'Script demo thực chiến: cấu hình, showcase dashboard WAF, Bot, API Shield, Access, Gateway, WARP cho SME.',
    en: 'Field demo scripts: configuration and dashboard walkthroughs for WAF, Bot, API Shield, Access, Gateway, WARP for SMEs.',
  }}
  canonicalPath="/demo-guides"
  showProgressBar
>
  <Breadcrumbs
    items={[
      { href: '/resources', label: { vi: 'Tài nguyên', en: 'Resources' } },
      { href: '/demo-guides', label: { vi: 'Script demo', en: 'Demo guides' } },
    ]}
  />

  <header class="mb-8">
    <LangText as="h1" class="text-2xl font-semibold md:text-3xl" text={{ vi: 'Script demo dashboard', en: 'Dashboard demo scripts' }} />
    <LangText as="p" class="text-muted mt-2 max-w-3xl text-sm leading-relaxed md:text-base" text={demoScriptsIntro} />
    <nav class="mt-4 flex flex-wrap gap-2 text-sm" aria-label="Demo guide sections">
      <a class="badge hover:border-[var(--cf-accent)]" href="#platform">
        <span class="lang-vi">Nền tảng</span>
        <span class="lang-en">Platform</span>
      </a>
      <a class="badge hover:border-[var(--cf-accent)]" href="#application-security">
        <span class="lang-vi">Application Security</span>
        <span class="lang-en">Application Security</span>
      </a>
      <a class="badge hover:border-[var(--cf-accent)]" href="#cloudflare-one">
        <span class="lang-vi">Cloudflare One</span>
        <span class="lang-en">Cloudflare One</span>
      </a>
      <a class="badge hover:border-[var(--cf-accent)]" href="/plans">
        <span class="lang-vi">So sánh gói SME</span>
        <span class="lang-en">SME plan comparison</span>
      </a>
    </nav>
  </header>

  <section id="platform" class="scroll-mt-24 mb-12">
    <LangText
      as="h2"
      class="mb-2 text-xl font-semibold"
      text={{ vi: 'Nền tảng — discovery & security route', en: 'Platform — discovery & security route' }}
    />
    <LangText
      as="p"
      class="text-muted mb-4 max-w-3xl text-sm"
      text={{
        vi: 'Bắt đầu mọi buổi demo: pitch reverse proxy, vòng đời request, tour Account Home và Security overview.',
        en: 'Start every demo: reverse proxy pitch, request lifecycle, Account Home and Security overview tour.',
      }}
    />
    <DemoVignetteList client:load vignettes={platformDemoVignettes} />
  </section>

  <section id="application-security" class="scroll-mt-24 mb-12">
    <LangText
      as="h2"
      class="mb-2 text-xl font-semibold"
      text={{ vi: 'Application Security (Advanced Security)', en: 'Application Security (Advanced Security)' }}
    />
    <LangText
      as="p"
      class="text-muted mb-4 max-w-3xl text-sm"
      text={{
        vi: 'Payload inspection, Advanced Rate Limiting, Bot Management, API Shield, Account WAF — gắn track Application Services.',
        en: 'Payload inspection, Advanced Rate Limiting, Bot Management, API Shield, Account WAF — tied to the Application Services track.',
      }}
    />
    <p class="mb-4 text-sm">
      <a class="link" href="/tracks/application-services">
        <span class="lang-vi">← Lộ trình Application Services</span>
        <span class="lang-en">← Application Services track</span>
      </a>
    </p>
    <DemoVignetteList client:load vignettes={applicationSecurityDemos} />
  </section>

  <section id="cloudflare-one" class="scroll-mt-24 mb-8">
    <LangText
      as="h2"
      class="mb-2 text-xl font-semibold"
      text={{ vi: 'Cloudflare One (Zero Trust)', en: 'Cloudflare One (Zero Trust)' }}
    />
    <LangText
      as="p"
      class="text-muted mb-4 max-w-3xl text-sm"
      text={{
        vi: 'WARP, Access, Tunnel, Gateway, RBI, DLP, CASB, Logs — cho SME thay VPN và kiểm soát Internet egress.',
        en: 'WARP, Access, Tunnel, Gateway, RBI, DLP, CASB, Logs — for SMEs replacing VPN and controlling Internet egress.',
      }}
    />
    <p class="mb-4 text-sm">
      <a class="link" href="/tracks/cloudflare-one">
        <span class="lang-vi">← Lộ trình Cloudflare One</span>
        <span class="lang-en">← Cloudflare One track</span>
      </a>
    </p>
    <DemoVignetteList client:load vignettes={cloudflareOneDemos} />
  </section>

  <aside class="card border-dashed p-4 text-xs leading-relaxed" style="border-color: var(--cf-border)">
    <LangText as="p" class="text-muted" text={demoScriptsDisclaimer} />
  </aside>
</BaseLayout>
