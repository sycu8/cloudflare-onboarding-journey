---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/chrome/Breadcrumbs.astro';
import LangText from '../components/ui/LangText.astro';
import CTASection from '../components/content/CTASection.astro';
import Cloudflare101Catalog from '../components/content/Cloudflare101Catalog.astro';
import { cf101Categories, cf101Foundations, developerDocsHome, docsUrl } from '../data/cloudflare101';
---

<BaseLayout
  title={{
    vi: 'Cloudflare 101: bản đồ sản phẩm theo Developer Docs',
    en: 'Cloudflare 101: product map aligned with Developer Docs',
  }}
  description={{
    vi: 'Khái niệm nền DNS/proxy/edge/origin và chú thích từng sản phẩm: Compute, AI, Storage, Media, Application Security, Cloudflare One.',
    en: 'Foundations plus annotated products: Compute, AI, Storage, Media, Application Security, Cloudflare One.',
  }}
  canonicalPath="/cloudflare-101"
  showProgressBar
>
  <Breadcrumbs items={[{ href: '/cloudflare-101', label: { vi: 'Cloudflare 101', en: 'Cloudflare 101' } }]} />

  <header class="mb-8">
    <LangText
      as="h1"
      class="text-2xl font-semibold md:text-3xl"
      text={{
        vi: 'Cloudflare 101 — bản đồ sản phẩm',
        en: 'Cloudflare 101 — product map',
      }}
    />
    <LangText
      as="p"
      class="text-muted mt-2 max-w-3xl text-sm leading-relaxed"
      text={{
        vi: 'Cấu trúc theo nhóm giống trang Cloudflare Developer Docs: mỗi chuyên mục gồm các dịch vụ con và chú thích ngắn bằng tiếng Việt (bật English only nếu cần).',
        en: 'Grouped like Cloudflare Developer Docs: each section lists sub-products with short explanations (toggle English only if needed).',
      }}
    />
    <p class="mt-3 text-sm">
      <a class="link font-medium" href={developerDocsHome} target="_blank" rel="noopener noreferrer">
        developers.cloudflare.com
      </a>
      <span class="text-muted lang-vi"> — nguồn chính thức khi triển khai thật.</span>
      <span class="text-muted lang-en"> — the canonical source for production work.</span>
    </p>
  </header>

  <nav
    class="card mb-8 flex flex-wrap gap-2 p-4 text-sm"
    aria-label="Cloudflare 101 sections"
  >
    <span class="text-muted w-full text-xs font-medium uppercase tracking-wide">
      <span class="lang-vi">Chuyên mục</span>
      <span class="lang-en">Sections</span>
    </span>
  {
    [
      { id: 'foundations', vi: 'Nền tảng', en: 'Foundations' },
      ...cf101Categories.map((c) => ({ id: c.id, vi: c.title.vi, en: c.title.en })),
    ].map((s) => (
      <a href={`#${s.id}`} class="badge hover:border-[var(--cf-accent)]">
        <span class="lang-vi">{s.vi}</span>
        <span class="lang-en">{s.en}</span>
      </a>
    ))
  }
  </nav>

  <section id="foundations" class="scroll-mt-24">
    <LangText
      as="h2"
      class="mb-2 text-xl font-semibold md:text-2xl"
      text={{ vi: 'Nền tảng — đọc trước', en: 'Foundations — read first' }}
    />
    <LangText
      as="p"
      class="text-muted mb-4 max-w-3xl text-sm"
      text={{
        vi: 'Bốn khái niệm giúp bạn đọc mọi sản phẩm phía dưới mà không bị lạc.',
        en: 'Four concepts that make every product section below easier to follow.',
      }}
    />
    <ul class="grid gap-3 sm:grid-cols-2">
      {
        cf101Foundations.map((p) => {
          const href = docsUrl(p.docsPath);
          return (
            <li class="card p-4">
              <div class="flex items-start justify-between gap-2">
                <LangText as="h3" class="text-base font-semibold" text={p.name} />
                {href ? (
                  <a href={href} class="link shrink-0 text-xs" target="_blank" rel="noopener noreferrer">
                    Docs
                  </a>
                ) : null}
              </div>
              <LangText as="p" class="text-muted mt-2 text-sm leading-relaxed" text={p.summary} />
            </li>
          );
        })
      }
    </ul>
  </section>

  <div class="mt-10 border-t pt-10" style="border-color: var(--cf-border)">
    <Cloudflare101Catalog categories={cf101Categories} />
  </div>

  <section class="card mt-10">
    <LangText as="h2" class="text-lg font-semibold" text={{ vi: 'Đọc sâu hơn', en: 'Go deeper' }} />
    <p class="text-muted mt-2 text-sm leading-relaxed">
      <span class="lang-vi">
        <a class="link" href="/first-week#platform-2026">Cập nhật 2026</a> ·
        <a class="link" href="/resources#reference-architecture">Reference Architecture</a> ·
        <a class="link" href="/resources#resource-hub">Resource Hub</a> ·
        <a class="link" href="https://cloudsecop.net/tag/cloudflare/" target="_blank" rel="noopener noreferrer">CloudSecOp</a>
      </span>
      <span class="lang-en">
        <a class="link" href="/first-week#platform-2026">2026 snapshot</a> ·
        <a class="link" href="/resources#reference-architecture">Reference Architecture</a> ·
        <a class="link" href="/resources#resource-hub">Resource Hub</a> ·
        <a class="link" href="https://cloudsecop.net/tag/cloudflare/" target="_blank" rel="noopener noreferrer">CloudSecOp</a>
      </span>
    </p>
  </section>

  <CTASection
    title={{ vi: 'Chọn lộ trình học', en: 'Choose your learning path' }}
    description={{
      vi: 'Sau khi nắm bản đồ sản phẩm, chọn track Application Services, Developer Platform hoặc Cloudflare One.',
      en: 'Once you know the product map, pick Application Services, Developer Platform, or Cloudflare One.',
    }}
    cta={{ href: '/choose-your-path', label: { vi: 'Chọn lộ trình', en: 'Choose your path' } }}
  />
</BaseLayout>
