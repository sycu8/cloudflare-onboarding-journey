---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/chrome/Breadcrumbs.astro';
import LangText from '../../components/ui/LangText.astro';
import UseCaseCatalog from '../../components/content/UseCaseCatalog.astro';
import { useCases } from '../../data/useCases';
---

<BaseLayout
  title={{ vi: 'Tình huống thực tế', en: 'Practical use cases' }}
  description={{
    vi: 'Các tình huống thực tế Cloudflare: bảo vệ website, API, VPN replacement, kết nối user an toàn, serverless, SaaS access — theo lộ trình học.',
    en: 'Practical Cloudflare scenarios: protect websites, APIs, VPN replacement, secure user connections, serverless, SaaS access — aligned with learning tracks.',
  }}
  canonicalPath="/use-cases"
  showProgressBar
>
  <Breadcrumbs items={[{ href: '/use-cases/', label: { vi: 'Tình huống thực tế', en: 'Use cases' } }]} />

  <header class="mb-8">
    <LangText as="h1" class="text-2xl font-semibold md:text-3xl" text={{ vi: 'Tình huống thực tế', en: 'Practical use cases' }} />
    <LangText
      as="p"
      class="text-muted mt-2 max-w-3xl text-sm leading-relaxed"
      text={{
        vi: `Danh sách ${useCases.length} kịch bản phổ biến — mỗi tình huống gắn một lộ trình học (Application Services, Developer Platform, Cloudflare One). Chọn tình huống gần nhu cầu của bạn nhất.`,
        en: `${useCases.length} common scenarios — each maps to a learning track (Application Services, Developer Platform, Cloudflare One). Pick the scenario closest to your need.`,
      }}
    />
    <p class="text-muted mt-3 text-sm">
      <a class="link" href="/choose-your-path">
        <LangText text={{ vi: 'Chưa chắc nhóm nào? Làm bài chọn lộ trình →', en: 'Not sure? Use the path selector →' }} />
      </a>
    </p>
  </header>

  <UseCaseCatalog />
</BaseLayout>
