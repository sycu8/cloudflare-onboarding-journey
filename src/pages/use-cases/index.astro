---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/chrome/Breadcrumbs.astro';
import LangText from '../../components/ui/LangText.astro';
import PathCard from '../../components/content/PathCard.astro';
import { useCaseTrackLabels, useCaseTrackOrder, getUseCasesByTrack } from '../../data/useCases';
---

<BaseLayout
  title={{ vi: 'Tình huống thực tế', en: 'Practical use cases' }}
  description={{
    vi: 'Chọn nhóm tình huống: Application Services, Developer Platform hoặc Cloudflare One.',
    en: 'Pick a scenario group: Application Services, Developer Platform, or Cloudflare One.',
  }}
  canonicalPath="/use-cases"
  showProgressBar
>
  <Breadcrumbs items={[{ href: '/use-cases', label: { vi: 'Tình huống thực tế', en: 'Use cases' } }]} />

  <header class="mb-8">
    <LangText as="h1" class="text-2xl font-semibold md:text-3xl" text={{ vi: 'Tình huống thực tế', en: 'Practical use cases' }} />
    <LangText
      as="p"
      class="text-muted mt-2 max-w-3xl text-sm leading-relaxed"
      text={{
        vi: 'Chọn một trong ba nhóm — mỗi nhóm có trang riêng và các tình huống chi tiết bên trong.',
        en: 'Choose one of three groups — each has its own page and detailed scenarios inside.',
      }}
    />
    <p class="text-muted mt-3 text-sm">
      <a class="link" href="/choose-your-path">
        <LangText text={{ vi: 'Chưa chắc nhóm nào? Làm bài chọn lộ trình →', en: 'Not sure? Use the path selector →' }} />
      </a>
    </p>
  </header>

  <div class="grid gap-4 md:grid-cols-3">
    {
      useCaseTrackOrder.map((trackKey) => {
        const meta = useCaseTrackLabels[trackKey];
        const count = getUseCasesByTrack(trackKey).length;
        return (
          <PathCard
            title={meta.title}
            description={meta.headline}
            cta={{
              href: `/use-cases/${trackKey}`,
              label: {
                vi: `${count} tình huống →`,
                en: `${count} scenarios →`,
              },
            }}
          />
        );
      })
    }
  </div>
</BaseLayout>
