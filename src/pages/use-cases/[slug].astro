---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/chrome/Breadcrumbs.astro';
import LangText from '../../components/ui/LangText.astro';
import CTASection from '../../components/content/CTASection.astro';
import { useCases } from '../../data/useCases';

export function getStaticPaths() {
  return useCases.map((u) => ({ params: { slug: u.slug } }));
}

const { slug } = Astro.params;
const uc = useCases.find((u) => u.slug === slug);
if (!uc) throw new Error('Use case not found');
---

<BaseLayout title={uc.title} description={uc.problem} canonicalPath={`/use-cases/${uc.slug}`} showProgressBar>
  <Breadcrumbs
    items={[
      { href: '/use-cases/protect-website', label: { vi: 'Tình huống thực tế', en: 'Use Cases' } },
      { href: `/use-cases/${uc.slug}`, label: uc.title },
    ]}
  />

  <header class="mb-6">
    <LangText as="h1" class="text-2xl font-semibold md:text-3xl" text={uc.title} />
    <LangText as="p" class="text-muted mt-2 max-w-3xl text-sm" text={uc.problem} />
  </header>

  <section class="card">
    <LangText as="h2" class="text-lg font-semibold" text={{ vi: 'Kiến trúc gợi ý', en: 'Suggested architecture' }} />
    <p class="mt-3 font-mono text-sm text-[var(--cf-accent)]">
      <span class="lang-vi">{uc.architecture.vi}</span>
      <span class="lang-en">{uc.architecture.en}</span>
    </p>
  </section>

  {uc.steps ? (
    <section class="card mt-6">
      <LangText as="h2" class="text-lg font-semibold" text={{ vi: 'Các bước thực hiện', en: 'Recommended steps' }} />
      <ol class="text-muted mt-3 list-decimal space-y-2 pl-5 text-sm">
        {uc.steps.vi.map((step, i) => (
          <li>
            <span class="lang-vi">{step}</span>
            <span class="lang-en">{uc.steps!.en[i]}</span>
          </li>
        ))}
      </ol>
    </section>
  ) : null}

  {uc.bullets ? (
    <section class="card mt-6">
      <LangText as="h2" class="text-lg font-semibold" text={{ vi: 'Controls & stack', en: 'Controls & stack' }} />
      <ul class="text-muted mt-3 list-disc space-y-2 pl-5 text-sm">
        {uc.bullets.vi.map((b, i) => (
          <li>
            <span class="lang-vi">{b}</span>
            <span class="lang-en">{uc.bullets!.en[i]}</span>
          </li>
        ))}
      </ul>
    </section>
  ) : null}

  {uc.commonMistakes ? (
    <section class="mt-6">
      <LangText as="h2" class="text-xl font-semibold" text={{ vi: 'Common mistakes', en: 'Common mistakes' }} />
      <div class="mt-4 grid gap-4 md:grid-cols-2">
        {uc.commonMistakes.vi.map((m, i) => (
          <div class="card">
            <h3 class="font-semibold">
              <span class="lang-vi">{m.title}</span>
              <span class="lang-en">{uc.commonMistakes!.en[i].title}</span>
            </h3>
            <p class="text-muted mt-2 text-sm">
              <span class="lang-vi">{m.detail}</span>
              <span class="lang-en">{uc.commonMistakes!.en[i].detail}</span>
            </p>
          </div>
        ))}
      </div>
    </section>
  ) : null}

  <CTASection
    title={{ vi: 'Next step', en: 'Next step' }}
    description={{ vi: 'Tiếp tục hành trình học của bạn.', en: 'Continue your learning journey.' }}
    cta={uc.nextCta}
  />
</BaseLayout>
