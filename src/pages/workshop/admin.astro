---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/chrome/Breadcrumbs.astro';
import LangText from '../../components/ui/LangText.astro';
import WorkshopAdminPanel from '../../components/interactive/WorkshopAdminPanel';
---

<BaseLayout
  title={{ vi: 'Admin workshop — thêm sự kiện', en: 'Workshop admin — manage events' }}
  description={{
    vi: 'Trang quản trị để admin tạo sự kiện workshop hiển thị trên hub.',
    en: 'Admin page to create workshop events shown on the hub.',
  }}
  canonicalPath="/workshop/admin"
  noindex
>
  <Breadcrumbs
    items={[
      { href: '/workshop', label: { vi: 'Hội thảo', en: 'Workshop' } },
      { href: '/workshop/admin', label: { vi: 'Admin', en: 'Admin' } },
    ]}
  />

  <header class="mb-6">
    <LangText as="h1" class="text-2xl font-semibold md:text-3xl" text={{ vi: 'Quản trị workshop', en: 'Workshop admin' }} />
    <LangText
      as="p"
      class="text-muted mt-2 max-w-2xl text-sm"
      text={{
        vi: 'Tạo sự kiện workshop mới — cần WORKSHOP_ADMIN_KEY đã cấu hình trên Cloudflare Pages.',
        en: 'Create new workshop events — requires WORKSHOP_ADMIN_KEY configured on Cloudflare Pages.',
      }}
    />
  </header>

  <WorkshopAdminPanel client:load />

  <p class="text-muted mt-6 text-sm">
    <a class="link" href="/workshop">
      <LangText text={{ vi: '← Về trang đăng ký workshop', en: '← Back to workshop registration' }} />
    </a>
  </p>
</BaseLayout>
