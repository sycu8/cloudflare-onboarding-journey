---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/chrome/Breadcrumbs.astro';
import LangText from '../../components/ui/LangText.astro';
import CTASection from '../../components/content/CTASection.astro';
import TrackModuleCard from '../../components/content/TrackModuleCard.astro';
import CloudsecopArticleCard from '../../components/content/CloudsecopArticleCard.astro';
import CloudsecopSeriesCard from '../../components/content/CloudsecopSeriesCard.astro';
import GitHubRepoCard from '../../components/content/GitHubRepoCard.astro';
import GitHubLearningPathCard from '../../components/content/GitHubLearningPathCard.astro';
import { tracks } from '../../data/tracks';
import { learningTopics } from '../../data/learningCenter';
import {
  getCloudsecopArticlesForTrack,
  getCloudsecopSeriesForTrack,
  CLOUDSECOP_TAG_URL,
} from '../../data/cloudsecop';
import {
  getGitHubReposForTrack,
  githubLearningPaths,
  CLOUDFLARE_GITHUB_ORG,
} from '../../data/githubRepos';
import ReferenceArchitectureCard from '../../components/content/ReferenceArchitectureCard.astro';
import ResourceHubCard from '../../components/content/ResourceHubCard.astro';
import {
  getReferenceItemsForTrack,
  REFERENCE_ARCHITECTURE_HUB_URL,
} from '../../data/referenceArchitecture';
import {
  getResourceHubForTrack,
  CLOUDFLARE_RESOURCE_HUB_URL,
} from '../../data/resourceHub';
import DemoVignetteList from '../../components/interactive/DemoVignetteList';
import { getDemosForTrack } from '../../data/demoScripts';

export function getStaticPaths() {
  return tracks.map((t) => ({ params: { slug: t.slug } }));
}

const { slug } = Astro.params;
const track = tracks.find((t) => t.slug === slug);
if (!track) throw new Error('Track not found');

const relatedTopics = learningTopics.filter((t) => t.relatedTrack === track.slug);

const cloudsecopReading =
  track.slug === 'developer-platform' || track.slug === 'cloudflare-one'
    ? getCloudsecopArticlesForTrack(track.slug, 6)
    : getCloudsecopArticlesForTrack('application-services', 6);

const cloudsecopSeries =
  track.slug === 'developer-platform' || track.slug === 'cloudflare-one'
    ? getCloudsecopSeriesForTrack(track.slug)
    : undefined;

const githubReading = getGitHubReposForTrack(track.slug, 4);
const githubPaths = githubLearningPaths.filter((p) => p.relatedTrack === track.slug);
const referenceReading = getReferenceItemsForTrack(track.slug, 4);
const resourceHubReading = getResourceHubForTrack(track.slug, 4);

const trackDemoVignettes =
  track.slug === 'application-services' || track.slug === 'cloudflare-one'
    ? getDemosForTrack(track.slug)
    : [];
---

<BaseLayout
  title={track.headline}
  description={track.promise}
  canonicalPath={`/tracks/${track.slug}`}
  showProgressBar
>
  <Breadcrumbs
    items={[
      { href: '/tracks', label: { vi: 'Lộ trình học', en: 'Tracks' } },
      { href: `/tracks/${track.slug}`, label: track.title },
    ]}
  />

  <header class="mb-8">
    <LangText as="h1" class="text-2xl font-semibold md:text-3xl" text={track.title} />
    <LangText as="p" class="text-muted mt-2 max-w-3xl text-base" text={track.headline} />
    <LangText as="p" class="text-muted mt-3 max-w-3xl text-sm leading-relaxed" text={track.description} />
  </header>

  <section class="card mb-6">
    <LangText as="h2" class="text-lg font-semibold" text={{ vi: 'Ai nên học lộ trình này?', en: 'Who is this for?' }} />
    <LangText as="p" class="text-muted mt-2 text-sm leading-relaxed" text={track.whoIsThisFor} />
  </section>

  <section class="card mb-6">
    <LangText as="h2" class="text-lg font-semibold" text={{ vi: 'Mô hình tư duy', en: 'Mental model' }} />
    <LangText as="p" class="text-muted mt-2 font-mono text-sm leading-relaxed" text={track.mentalModel} />
  </section>

  <section class="card mb-6">
    <LangText as="h2" class="text-lg font-semibold" text={{ vi: 'Sau lộ trình bạn sẽ', en: 'What you will achieve' }} />
    <ul class="text-muted mt-3 list-disc space-y-2 pl-5 text-sm">
      {track.outcomes.vi.map((item, i) => (
        <li>
          <span class="lang-vi">{item}</span>
          <span class="lang-en">{track.outcomes.en[i]}</span>
        </li>
      ))}
    </ul>
  </section>

  <section class="card mb-8">
    <LangText as="h2" class="text-lg font-semibold" text={{ vi: 'Khái niệm cần nắm', en: 'Key concepts' }} />
    <ul class="mt-3 flex flex-wrap gap-2">
      {track.keyConcepts.map((k) => (
        <li class="badge">{k}</li>
      ))}
    </ul>
  </section>

  <section class="mb-8">
    <LangText as="h2" class="mb-4 text-xl font-semibold" text={{ vi: 'Nội dung từng phần', en: 'Module-by-module content' }} />
    <div class="space-y-6">
      {track.modules.map((mod, i) => (
        <TrackModuleCard module={mod} />
      ))}
    </div>
  </section>

  <section class="grid gap-6 md:grid-cols-2 mb-8">
    <div class="card">
      <LangText as="h2" class="text-lg font-semibold" text={{ vi: 'Trình tự học gợi ý', en: 'Suggested learning order' }} />
      <ol class="text-muted mt-3 list-decimal space-y-2 pl-5 text-sm">
        {track.recommendedSequence.vi.map((step, i) => (
          <li>
            <span class="lang-vi">{step}</span>
            <span class="lang-en">{track.recommendedSequence.en[i]}</span>
          </li>
        ))}
      </ol>
    </div>
    <div class="card">
      <LangText as="h2" class="text-lg font-semibold" text={{ vi: 'Tình huống liên quan', en: 'Related use cases' }} />
      <ul class="mt-3 space-y-2 text-sm">
        {track.relatedUseCases.map((uc) => (
          <li>
            <a class="link" href={uc.href}>
              <LangText text={uc.label} />
            </a>
          </li>
        ))}
      </ul>
      <LangText as="h3" class="mt-6 text-base font-semibold" text={{ vi: 'Chủ đề Learning Center', en: 'Learning Center topics' }} />
      <ul class="text-muted mt-3 space-y-2 text-sm">
        {relatedTopics.slice(0, 5).map((t) => (
          <li>
            <a class="link" href={t.officialPath} target="_blank" rel="noopener noreferrer">
              <span class="lang-vi">{t.title.vi}</span>
              <span class="lang-en">{t.title.en}</span>
              {' '}↗
            </a>
          </li>
        ))}
      </ul>
      <a class="link mt-3 inline-block text-sm" href="/resources#learning-center">
        <LangText text={{ vi: 'Xem tất cả chủ đề', en: 'View all topics' }} />
      </a>
    </div>
  </section>

  {trackDemoVignettes.length > 0 ? (
    <section id="demo-guides" class="mb-8 scroll-mt-24">
      <LangText
        as="h2"
        class="text-xl font-semibold"
        text={{ vi: 'Script demo dashboard (thực chiến)', en: 'Field demo scripts (dashboard)' }}
      />
      <LangText
        as="p"
        class="text-muted mt-2 max-w-3xl text-sm leading-relaxed"
        text={{
          vi: 'Cấu hình theo nhu cầu khách hàng — đường dẫn menu, bước showcase và mẹo demo từ playbook SE. Mở rộng đầy đủ trên trang Script demo.',
          en: 'Configure to customer needs — menu paths, showcase steps, and SE playbook tips. Full library on the Demo guides page.',
        }}
      />
      <a class="link mt-2 inline-block text-sm" href="/demo-guides">
        <span class="lang-vi">Xem tất cả script (kèm phần nền tảng) →</span>
        <span class="lang-en">View all scripts (including platform) →</span>
      </a>
      <div class="mt-6">
        <DemoVignetteList client:load vignettes={trackDemoVignettes} />
      </div>
    </section>
  ) : null}

  {resourceHubReading.length > 0 ? (
    <section id="resource-hub-reading" class="mb-8">
      <LangText
        as="h2"
        class="text-xl font-semibold"
        text={{ vi: 'Tài nguyên chính thức (Resource Hub)', en: 'Official resources (Resource Hub)' }}
      />
      <p class="text-muted mt-2 max-w-3xl text-sm leading-relaxed">
        <span class="lang-vi">
          Liên kết từ{' '}
          <a class="link" href={CLOUDFLARE_RESOURCE_HUB_URL} target="_blank" rel="noopener noreferrer">
            Cloudflare Resource Hub
          </a>
          — docs, community, case studies phù hợp track này.
        </span>
        <span class="lang-en">
          Links from the{' '}
          <a class="link" href={CLOUDFLARE_RESOURCE_HUB_URL} target="_blank" rel="noopener noreferrer">
            Cloudflare Resource Hub
          </a>
          — docs, community, and case studies for this track.
        </span>
      </p>
      <div class="mt-6 grid gap-4 md:grid-cols-2">
        {resourceHubReading.map((item) => (
          <ResourceHubCard item={item} />
        ))}
      </div>
      <a class="link mt-4 inline-block text-sm" href="/resources#resource-hub">
        <LangText text={{ vi: 'Xem toàn bộ Resource Hub trong hub', en: 'View full Resource Hub in this hub' }} />
      </a>
    </section>
  ) : null}

  {referenceReading.length > 0 ? (
    <section id="reference-architecture-reading" class="mb-8">
      <LangText
        as="h2"
        class="text-xl font-semibold"
        text={{ vi: 'Reference Architecture', en: 'Reference Architecture' }}
      />
      <p class="text-muted mt-2 max-w-3xl text-sm leading-relaxed">
        <span class="lang-vi">
          Sơ đồ và tài liệu thiết kế chính thức từ{' '}
          <a class="link" href={REFERENCE_ARCHITECTURE_HUB_URL} target="_blank" rel="noopener noreferrer">
            Cloudflare Architecture Center
          </a>
          — bổ sung lộ trình học trong hub.
        </span>
        <span class="lang-en">
          Official design diagrams and docs from the{' '}
          <a class="link" href={REFERENCE_ARCHITECTURE_HUB_URL} target="_blank" rel="noopener noreferrer">
            Cloudflare Architecture Center
          </a>
          — complementing this track in the hub.
        </span>
      </p>
      <div class="mt-6 grid gap-4 md:grid-cols-2">
        {referenceReading.map((item) => (
          <ReferenceArchitectureCard item={item} />
        ))}
      </div>
      <a class="link mt-4 inline-block text-sm" href="/resources#reference-architecture">
        <LangText text={{ vi: 'Xem tất cả tài liệu kiến trúc', en: 'View all architecture docs' }} />
      </a>
    </section>
  ) : null}

  {githubPaths.length > 0 || githubReading.length > 0 ? (
    <section id="github-examples" class="mb-8">
      <LangText
        as="h2"
        class="text-xl font-semibold"
        text={{ vi: 'Ví dụ từ GitHub Cloudflare', en: 'Examples from Cloudflare GitHub' }}
      />
      <p class="text-muted mt-2 max-w-3xl text-sm leading-relaxed">
        <span class="lang-vi">
          Repo open source chính thức trên <a class="link" href={CLOUDFLARE_GITHUB_ORG} target="_blank" rel="noopener noreferrer">github.com/cloudflare</a> — học bằng README và code mẫu.
        </span>
        <span class="lang-en">
          Official open source at <a class="link" href={CLOUDFLARE_GITHUB_ORG} target="_blank" rel="noopener noreferrer">github.com/cloudflare</a> — learn from READMEs and sample code.
        </span>
      </p>
      {githubPaths.length > 0 ? (
        <div class="mt-4 grid gap-4 md:grid-cols-2">
          {githubPaths.map((path) => (
            <GitHubLearningPathCard path={path} />
          ))}
        </div>
      ) : null}
      {githubReading.length > 0 ? (
        <div class="mt-6 grid gap-4 md:grid-cols-2 lg:grid-cols-4">
          {githubReading.map((repo) => (
            <GitHubRepoCard repo={repo} />
          ))}
        </div>
      ) : null}
      <a class="link mt-4 inline-block text-sm" href="/resources#github">
        <LangText text={{ vi: 'Xem tất cả repo gợi ý', en: 'View all suggested repos' }} />
      </a>
    </section>
  ) : null}

  <section id="cloudsecop-reading" class="mb-8">
    <LangText
      as="h2"
      class="text-xl font-semibold"
      text={{ vi: 'Đọc thêm — kinh nghiệm thực tế (CloudSecOp)', en: 'Further reading — field notes (CloudSecOp)' }}
    />
    <p class="text-muted mt-2 max-w-3xl text-sm leading-relaxed">
      <span class="lang-vi">
        Bài viết từ <a class="link" href={CLOUDSECOP_TAG_URL} target="_blank" rel="noopener noreferrer">cloudsecop.net</a> — bổ sung lộ trình hub với context triển khai production, không thay tài liệu chính thức Cloudflare.
      </span>
      <span class="lang-en">
        Posts from <a class="link" href={CLOUDSECOP_TAG_URL} target="_blank" rel="noopener noreferrer">cloudsecop.net</a> — complement this track with production deployment context; not a replacement for official Cloudflare docs.
      </span>
    </p>
    {cloudsecopSeries ? (
      <div class="mt-4 max-w-xl">
        <CloudsecopSeriesCard series={cloudsecopSeries} />
      </div>
    ) : null}
    {cloudsecopReading.length > 0 ? (
      <div class="mt-6 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {cloudsecopReading.map((article) => (
          <CloudsecopArticleCard article={article} />
        ))}
      </div>
    ) : null}
    <a class="link mt-4 inline-block text-sm" href="/resources#cloudsecop">
      <LangText text={{ vi: 'Xem tất cả bài gợi ý trong Tài nguyên', en: 'View all suggested posts in Resources' }} />
    </a>
  </section>

  <CTASection
    title={{ vi: 'Bước tiếp theo', en: 'Next step' }}
    description={{ vi: 'Áp dụng ngay qua tình huống thực tế và checklist.', en: 'Apply what you learned via a use case and checklist.' }}
    cta={track.cta}
  />
</BaseLayout>
