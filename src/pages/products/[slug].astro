---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/chrome/Breadcrumbs.astro';
import LangText from '../../components/ui/LangText.astro';
import CTASection from '../../components/content/CTASection.astro';
import ReferenceDiagramFigure from '../../components/content/ReferenceDiagramFigure.astro';
import { productPages, getProductBySlug } from '../../data/productPages';
import { getDiagramBySlug } from '../../data/referenceDiagrams';
import { tracks } from '../../data/tracks';

export function getStaticPaths() {
  return productPages.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const product = getProductBySlug(slug!);
if (!product) throw new Error(`Product not found: ${slug}`);

const diagrams = product.diagramSlugs
  .map((s) => getDiagramBySlug(s))
  .filter((d): d is NonNullable<ReturnType<typeof getDiagramBySlug>> => !!d)
  .slice(0, 2);
const heroImage = diagrams[0]?.primaryImageUrl;
const track = tracks.find((t) => t.slug === product.relatedTrack);
const related = product.relatedProductSlugs
  .map((s) => getProductBySlug(s))
  .filter((p): p is NonNullable<typeof p> => !!p);
---

<BaseLayout
  title={{
    vi: `${product.name.vi} là gì? · Cloudflare cho người mới`,
    en: `What is ${product.name.en}? · Cloudflare for beginners`,
  }}
  description={product.summary}
  canonicalPath={`/products/${product.slug}`}
  showProgressBar
>
  <Breadcrumbs
    items={[
      { href: '/cloudflare-101', label: { vi: 'Cloudflare 101', en: 'Cloudflare 101' } },
      { href: '/products', label: { vi: 'Sản phẩm', en: 'Products' } },
      { href: `/products/${product.slug}`, label: product.name },
    ]}
  />

  <header class="mb-8">
    <p class="text-muted mb-2 text-xs font-medium uppercase tracking-wide">
      <LangText text={product.categoryLabel} />
    </p>
    <LangText as="h1" class="text-2xl font-semibold md:text-3xl" text={product.name} />
    <LangText as="p" class="text-muted mt-3 max-w-3xl text-sm leading-relaxed md:text-base" text={product.summary} />
    <div class="mt-4 flex flex-wrap gap-2">
      {product.docsUrl ? (
        <a class="btn btn-primary" href={product.docsUrl} target="_blank" rel="noopener noreferrer">
          <LangText text={{ vi: 'Tài liệu chính thức ↗', en: 'Official docs ↗' }} />
        </a>
      ) : null}
      <a class="btn btn-secondary" href="/glossary">
        <LangText text={{ vi: 'Thuật ngữ liên quan', en: 'Related glossary' }} />
      </a>
      {track ? (
        <a class="btn btn-secondary" href={`/tracks/${track.slug}`}>
          <LangText text={{ vi: `Lộ trình: ${track.title.vi}`, en: `Track: ${track.title.en}` }} />
        </a>
      ) : null}
    </div>
  </header>

  {heroImage ? (
    <figure class="card mb-8 overflow-hidden p-0">
      <img
        src={heroImage}
        alt={product.name.en}
        loading="eager"
        decoding="async"
        class="w-full max-h-[22rem] object-contain bg-[var(--cf-bg-elevated)] p-4"
      />
      <figcaption class="text-muted border-t border-[var(--cf-border)] px-4 py-2 text-xs">
        <span class="lang-vi">Sơ đồ tham chiếu từ Cloudflare Developer Docs — bấm vào sơ đồ bên dưới để xem bản đầy đủ.</span>
        <span class="lang-en">Reference figure from Cloudflare Developer Docs — see diagrams below for the full official version.</span>
      </figcaption>
    </figure>
  ) : null}

  <div class="grid gap-6 lg:grid-cols-2">
    <section class="card">
      <LangText as="h2" class="text-lg font-semibold" text={{ vi: 'Là gì?', en: 'What is it?' }} />
      <LangText as="p" class="text-muted mt-3 text-sm leading-relaxed" text={product.detail.whatIs} />
    </section>
    <section class="card">
      <LangText as="h2" class="text-lg font-semibold" text={{ vi: 'Tại sao quan trọng?', en: 'Why it matters' }} />
      <LangText as="p" class="text-muted mt-3 text-sm leading-relaxed" text={product.detail.whyItMatters} />
    </section>
  </div>

  <section class="card mt-6">
    <LangText as="h2" class="text-lg font-semibold" text={{ vi: 'Khi nào nên dùng?', en: 'When to use it' }} />
    <ul class="text-muted mt-3 list-disc space-y-2 pl-5 text-sm">
      {product.detail.whenToUse.vi.map((item, i) => (
        <li>
          <span class="lang-vi">{item}</span>
          <span class="lang-en">{product.detail.whenToUse.en[i]}</span>
        </li>
      ))}
    </ul>
  </section>

  <section class="card mt-6">
    <LangText as="h2" class="text-lg font-semibold" text={{ vi: 'Ví dụ đơn giản', en: 'Simple example' }} />
    <LangText as="p" class="text-muted mt-3 text-sm leading-relaxed" text={product.detail.simpleExample} />
    {product.detail.commonConfusion ? (
      <LangText as="p" class="text-muted mt-4 border-t border-[var(--cf-border)] pt-4 text-sm italic" text={product.detail.commonConfusion} />
    ) : null}
  </section>

  {diagrams.length > 0 ? (
    <section class="mt-8">
      <LangText
        as="h2"
        class="mb-4 text-lg font-semibold"
        text={{ vi: 'Hình ảnh trực quan (Cloudflare Docs)', en: 'Visual guides (Cloudflare Docs)' }}
      />
      <div class="grid gap-6 lg:grid-cols-2">
        {diagrams.map((d) => (
          <ReferenceDiagramFigure diagram={d} />
        ))}
      </div>
    </section>
  ) : null}

  {related.length > 0 ? (
    <section class="mt-8">
      <LangText as="h2" class="mb-4 text-lg font-semibold" text={{ vi: 'Sản phẩm liên quan', en: 'Related products' }} />
      <ul class="grid gap-3 sm:grid-cols-2">
        {related.map((r) => (
          <li>
            <a href={`/products/${r.slug}`} class="card block p-4 transition hover:border-[var(--cf-accent)]">
              <LangText as="span" class="font-semibold" text={r.name} />
              <LangText as="p" class="text-muted mt-1 line-clamp-2 text-sm" text={r.summary} />
            </a>
          </li>
        ))}
      </ul>
    </section>
  ) : null}

  <CTASection
    title={{ vi: 'Tiếp theo', en: 'Next step' }}
    description={{
      vi: 'Quay lại bản đồ sản phẩm hoặc chọn lộ trình học phù hợp.',
      en: 'Return to the product map or pick a learning track.',
    }}
    cta={{
      href: '/choose-your-path',
      label: { vi: 'Chọn lộ trình', en: 'Choose your path' },
    }}
  />
</BaseLayout>
