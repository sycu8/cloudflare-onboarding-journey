---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/chrome/Breadcrumbs.astro';
import LangText from '../components/ui/LangText.astro';
import CTASection from '../components/content/CTASection.astro';
import RoadmapModuleCard from '../components/roadmap/RoadmapModuleCard.astro';
import RoadmapProgress from '../components/roadmap/RoadmapProgress';
import ContentRoadmapExplorer from '../components/roadmap/ContentRoadmapExplorer';
import RoadmapTopicBinder from '../components/roadmap/RoadmapTopicBinder';
import { contentRoadmapStages, getStageMinutes, getTotalTopicCount } from '../data/contentRoadmap';
import { roleRoadmaps } from '../data/roleRoadmaps';

const totalTopics = getTotalTopicCount();
---

<BaseLayout
  title={{ vi: 'Content Roadmap: Học Cloudflare từ nền tảng Internet', en: 'Content Roadmap: Learn Cloudflare from Internet foundations' }}
  description={{
    vi: 'Lộ trình học từ Internet, DNS, CDN, TLS, WAF, Zero Trust đến Cloudflare Workers cho người mới bắt đầu.',
    en: 'Learning path from Internet, DNS, CDN, TLS, WAF, and Zero Trust to Cloudflare Workers for beginners.',
  }}
  canonicalPath="/content-roadmap"
  showProgressBar
>
  <Breadcrumbs
    items={[
      { href: '/start-here', label: { vi: 'Bắt đầu', en: 'Start' } },
      { href: '/content-roadmap', label: { vi: 'Content Roadmap', en: 'Content Roadmap' } },
    ]}
  />

  <header class="mb-6">
    <LangText
      as="h1"
      class="text-2xl font-semibold md:text-3xl"
      text={{ vi: 'Bắt đầu từ con số 0', en: 'Start from zero' }}
    />
    <LangText
      as="p"
      class="text-muted mt-2 max-w-3xl text-sm leading-relaxed"
      text={{
        vi: `Lộ trình ${contentRoadmapStages.length} giai đoạn · ${totalTopics} chủ đề — từ Internet và mạng cơ bản đến use case thực tế trên Cloudflare. Mỗi chủ đề có nguồn tham khảo chính thức và liên kết nội dung sẵn có trên hub.`,
        en: `${contentRoadmapStages.length} stages · ${totalTopics} topics — from Internet basics to practical Cloudflare use cases, with official sources and hub links.`,
      }}
    />
  </header>

  <div class="mb-6 space-y-4">
    <RoadmapProgress client:load totalTopics={totalTopics} />
    <ContentRoadmapExplorer client:load />
  </div>

  <div class="space-y-12">
    {
      contentRoadmapStages.map((stage, index) => {
        const minutes = getStageMinutes(stage);
        return (
          <section
            class="space-y-4"
            id={stage.id}
            data-roadmap-stage
            data-stage-filters={stage.filterTags.join(',')}
          >
            <header class="border-b border-[var(--cf-border)] pb-4">
              <p class="text-muted text-xs font-semibold uppercase tracking-wide">
                <span class="lang-vi">Giai đoạn {index}</span>
                <span class="lang-en">Stage {index}</span>
              </p>
              <h2 class="mt-1 text-xl font-semibold md:text-2xl">
                <span class="lang-vi">{stage.titleVi}</span>
                <span class="lang-en">{stage.titleEn ?? stage.titleVi}</span>
              </h2>
              <p class="text-muted mt-2 max-w-3xl text-sm">
                <span class="lang-vi">{stage.descriptionVi}</span>
                <span class="lang-en">{stage.descriptionVi}</span>
              </p>
              <p class="mt-3 text-sm">
                <span class="font-medium lang-vi">Sau giai đoạn này bạn sẽ: </span>
                <span class="font-medium lang-en">After this stage you will: </span>
                <span class="text-muted">{stage.learnerOutcomeVi}</span>
              </p>
              <p class="text-muted mt-2 text-xs">
                <span class="lang-vi">~{minutes} phút · {stage.topics.length} chủ đề</span>
                <span class="lang-en">~{minutes} min · {stage.topics.length} topics</span>
              </p>
            </header>

            <div class="grid gap-4 lg:grid-cols-2">
              {stage.topics.map((topic) => (
                <div data-roadmap-topic-card data-topic-filters={topic.filterTags.join(',')}>
                  <RoadmapModuleCard topic={topic} stageIndex={index} />
                </div>
              ))}
            </div>

            <div class="card flex flex-wrap gap-2 border-dashed">
              <a class="btn btn-secondary text-sm" href={index < contentRoadmapStages.length - 1 ? `#${contentRoadmapStages[index + 1]?.id}` : '/roadmaps/'}>
                <span class="lang-vi">Học tiếp</span>
                <span class="lang-en">Continue</span>
              </a>
              <a class="btn btn-ghost text-sm" href="/glossary/">
                <span class="lang-vi">Xem glossary</span>
                <span class="lang-en">Glossary</span>
              </a>
              <a class="btn btn-ghost text-sm" href="/checklists/beginner-cloudflare-checklist/">
                <span class="lang-vi">Làm checklist</span>
                <span class="lang-en">Checklist</span>
              </a>
              <a class="btn btn-ghost text-sm" href="/quiz/beginner-readiness/">
                <span class="lang-vi">Làm quiz</span>
                <span class="lang-en">Quiz</span>
              </a>
            </div>
          </section>
        );
      })
    }
  </div>

  <section class="mt-12">
    <LangText as="h2" class="text-xl font-semibold" text={{ vi: 'Lộ trình theo vai trò', en: 'Role-based roadmaps' }} />
    <p class="text-muted mt-2 max-w-2xl text-sm">
      <span class="lang-vi">Đã nắm nền tảng? Chọn roadmap phù hợp với vai trò của bạn.</span>
      <span class="lang-en">Got the foundations? Pick a roadmap for your role.</span>
    </p>
    <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {roleRoadmaps.map((r) => (
        <a class="card block hover:border-[var(--cf-accent)]" href={`/roadmaps/${r.roleId}/`}>
          <p class="font-semibold">
            <span class="lang-vi">{r.roleNameVi}</span>
            <span class="lang-en">{r.roleNameEn ?? r.roleNameVi}</span>
          </p>
          <p class="text-muted mt-1 text-xs">
            <span class="lang-vi">{r.totalWeeks} tuần</span>
            <span class="lang-en">{r.totalWeeks} weeks</span>
          </p>
        </a>
      ))}
    </div>
  </section>

  <CTASection
    title={{ vi: 'Tiếp theo trên hub', en: 'Next on the hub' }}
    description={{
      vi: 'Cloudflare 101, lộ trình chi tiết, quiz và checklist.',
      en: 'Cloudflare 101, detailed tracks, quiz, and checklist.',
    }}
    cta={{ href: '/cloudflare-101/', label: { vi: 'Vào Cloudflare 101', en: 'Open Cloudflare 101' } }}
  />

  <RoadmapTopicBinder client:load />
</BaseLayout>
