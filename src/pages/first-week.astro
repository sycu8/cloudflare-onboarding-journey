---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/chrome/Breadcrumbs.astro';
import LangText from '../components/ui/LangText.astro';
import CTASection from '../components/content/CTASection.astro';
import {
  firstWeekIntro,
  firstWeekDays,
  beginnerMistakes,
  platformSnapshot2026,
  platformSnapshotNote,
} from '../data/beginnerJourney';
---

<BaseLayout
  title={{ vi: 'Tuần đầu học Cloudflare (7 ngày)', en: 'Your first week learning Cloudflare (7 days)' }}
  description={{
    vi: 'Lộ trình 7 ngày cho người mới: mental model, chọn track, checklist, thử sandbox và kế hoạch 30 ngày.',
    en: 'A 7-day path for beginners: mental model, track selection, checklist, sandbox try, and a 30-day plan.',
  }}
  canonicalPath="/first-week"
  showProgressBar
>
  <Breadcrumbs
    items={[
      { href: '/start-here', label: { vi: 'Bắt đầu', en: 'Start Here' } },
      { href: '/first-week', label: { vi: 'Tuần đầu', en: 'First week' } },
    ]}
  />

  <header class="mb-8">
    <LangText as="h1" class="text-2xl font-semibold md:text-3xl" text={{ vi: 'Tuần đầu học Cloudflare', en: 'Your first week with Cloudflare' }} />
    <LangText as="p" class="text-muted mt-2 max-w-3xl text-sm md:text-base" text={firstWeekIntro} />
  </header>

  <section class="space-y-6">
    {firstWeekDays.map((d) => (
      <article class="card">
        <div class="flex flex-wrap items-center gap-2">
          <span class="badge badge-accent">
            <span class="lang-vi">Ngày {d.day}</span>
            <span class="lang-en">Day {d.day}</span>
          </span>
        </div>
        <LangText as="h2" class="mt-3 text-lg font-semibold" text={d.title} />
        <LangText as="p" class="text-muted mt-2 text-sm font-medium" text={d.goal} />
        <ul class="text-muted mt-4 list-inside list-disc space-y-2 text-sm">
          {d.tasks.map((t) => (
            <li>
              <span class="lang-vi">{t.vi}</span>
              <span class="lang-en">{t.en}</span>
            </li>
          ))}
        </ul>
        <div class="mt-4 flex flex-wrap gap-2">
          {d.hubLinks.map((link) => (
            <a class="btn btn-secondary text-sm" href={link.href} target={link.href.startsWith('http') ? '_blank' : undefined} rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}>
              <LangText text={link.label} />
            </a>
          ))}
        </div>
      </article>
    ))}
  </section>

  <section class="mt-10">
    <LangText as="h2" class="text-xl font-semibold" text={{ vi: 'Sai lầm phổ biến (tránh sớm)', en: 'Common mistakes (avoid early)' }} />
    <div class="mt-4 grid gap-4 md:grid-cols-2">
      {beginnerMistakes.map((m) => (
        <article class="card">
          <LangText as="h3" class="font-semibold" text={m.mistake} />
          <LangText as="p" class="text-muted mt-2 text-sm" text={m.why} />
          <p class="mt-3 text-sm">
            <span class="lang-vi font-medium text-[var(--color-accent)]">Thay vào đó: </span>
            <span class="lang-en font-medium text-[var(--color-accent)]">Instead: </span>
            <span class="lang-vi">{m.instead.vi}</span>
            <span class="lang-en">{m.instead.en}</span>
          </p>
        </article>
      ))}
    </div>
  </section>

  <section id="platform-2026" class="mt-10">
    <LangText as="h2" class="text-xl font-semibold" text={{ vi: 'Cập nhật nền tảng (2026)', en: 'Platform snapshot (2026)' }} />
    <LangText as="p" class="text-muted mt-2 max-w-3xl text-sm" text={platformSnapshotNote} />
    <div class="mt-6 grid gap-4 md:grid-cols-2">
      {platformSnapshot2026.map((item) => (
        <article class="card flex h-full flex-col">
          <div class="flex flex-wrap gap-2">
            <span class="badge">
              {item.status === 'preview' ? (
                <>
                  <span class="lang-vi">Preview</span>
                  <span class="lang-en">Preview</span>
                </>
              ) : item.status === 'renamed' ? (
                <>
                  <span class="lang-vi">Đổi tên</span>
                  <span class="lang-en">Renamed</span>
                </>
              ) : (
                <>
                  <span class="lang-vi">Hiện tại</span>
                  <span class="lang-en">Current</span>
                </>
              )}
            </span>
          </div>
          <LangText as="h3" class="mt-3 font-semibold" text={item.title} />
          <LangText as="p" class="text-muted mt-2 flex-1 text-sm" text={item.summary} />
          <a class="link mt-3 text-sm" href={item.docsHref} target="_blank" rel="noopener noreferrer">
            <LangText text={{ vi: 'Docs chính thức', en: 'Official docs' }} /> ↗
          </a>
        </article>
      ))}
    </div>
  </section>

  <CTASection
    title={{ vi: 'Sẵn sàng kiểm tra kiến thức?', en: 'Ready for a knowledge check?' }}
    description={{
      vi: 'Sau tuần đầu, làm bài 12 câu để xem bạn nắm mental model đến đâu.',
      en: 'After your first week, take the 12-question check to see how solid your mental model is.',
    }}
    cta={{ href: '/quiz/beginner-readiness', label: { vi: 'Làm bài kiểm tra', en: 'Take knowledge check' } }}
  />
</BaseLayout>
