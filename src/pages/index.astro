---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/content/HeroSection.astro';
import ConceptCard from '../components/content/ConceptCard.astro';
import PathCard from '../components/content/PathCard.astro';
import JourneyStepper from '../components/content/JourneyStepper.astro';
import LangText from '../components/ui/LangText.astro';
import CTASection from '../components/content/CTASection.astro';
---

<BaseLayout
  title={{ vi: 'Bắt đầu học Cloudflare từ con số 0', en: 'Start learning Cloudflare from zero' }}
  description={{
    vi: 'Học Cloudflare từ con số 0: DNS, CDN, Workers, Zero Trust. Lộ trình 3 track, checklist, quiz 12 câu, tài nguyên chính thức và lộ trình 7 ngày — tiếng Việt & English.',
    en: 'Learn Cloudflare from zero: DNS, CDN, Workers, Zero Trust. Three tracks, checklists, a 12-question quiz, official resources, and a 7-day path — Vietnamese & English.',
  }}
  canonicalPath="/"
>
  <HeroSection
    eyebrow={{ vi: 'Cloudflare Starter Hub', en: 'Cloudflare Starter Hub' }}
    badge={{ vi: 'Người mới', en: 'Beginners' }}
    title={{ vi: 'Bắt đầu học Cloudflare từ con số 0.', en: 'Start learning Cloudflare from zero.' }}
    subtitle={{
      vi: 'Một learning hub thân thiện cho người mới bắt đầu tìm hiểu Cloudflare Application Services, Developer Platform và Cloudflare One — không bị ngợp bởi quá nhiều tên sản phẩm.',
      en: 'A beginner-friendly learning hub for understanding Cloudflare Application Services, Developer Platform, and Cloudflare One — without getting lost in product names.',
    }}
    primaryCta={{ href: '/start-here', label: { vi: 'Bắt đầu tại đây', en: 'Start here' } }}
    secondaryCta={{ href: '/first-week', label: { vi: 'Lộ trình 7 ngày', en: '7-day path' } }}
  />

  <section class="mt-10">
    <LangText as="h2" class="text-xl font-semibold md:text-2xl" text={{ vi: 'Hiểu Cloudflare theo 3 lớp đơn giản', en: 'Cloudflare in 3 simple layers' }} />
    <div class="mt-4 grid gap-4 md:grid-cols-3">
      <ConceptCard
        title={{ vi: 'Protect applications', en: 'Protect applications' }}
        description={{
          vi: 'Bảo vệ website, application và API khỏi tấn công, abuse, downtime và các vấn đề performance.',
          en: 'Protect websites, applications, and APIs from attacks, abuse, downtime, and performance issues.',
        }}
      />
      <ConceptCard
        title={{ vi: 'Build applications', en: 'Build applications' }}
        description={{
          vi: 'Build và deploy frontend app, API, storage-backed application và AI workload trên Cloudflare.',
          en: 'Build and deploy frontend apps, APIs, storage-backed applications, and AI workloads on Cloudflare.',
        }}
      />
      <ConceptCard
        title={{ vi: 'Secure users and workforce', en: 'Secure users and workforce' }}
        description={{
          vi: 'Bảo vệ quyền truy cập vào SaaS, private apps, Internet browsing, users, devices và networks bằng Zero Trust.',
          en: 'Secure access to SaaS, private apps, Internet browsing, users, devices, and networks with Zero Trust.',
        }}
      />
    </div>
  </section>

  <section class="mt-10">
    <div class="card mb-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <LangText as="h2" class="text-lg font-semibold" text={{ vi: 'Từ Cloudflare Learning Center', en: 'From Cloudflare Learning Center' }} />
        <p class="text-muted mt-1 text-sm">
          <span class="lang-vi">17 chủ đề: DDoS, CDN, DNS, Zero Trust, serverless, AI…</span>
          <span class="lang-en">17 topics: DDoS, CDN, DNS, Zero Trust, serverless, AI…</span>
        </p>
      </div>
      <a class="btn btn-secondary shrink-0" href="/resources#learning-center">
        <LangText text={{ vi: 'Xem chủ đề', en: 'Browse topics' }} />
      </a>
    </div>
    <LangText as="h2" class="text-xl font-semibold md:text-2xl" text={{ vi: 'Pick your starting point', en: 'Pick your starting point' }} />
    <div class="mt-4 grid gap-4 md:grid-cols-3">
      <PathCard
        title={{ vi: 'Tôi có website, application hoặc API', en: 'I have a website, application, or API' }}
        description={{
          vi: 'Học DNS, CDN, SSL/TLS, WAF, DDoS, Bot protection, API security và performance.',
          en: 'Learn DNS, CDN, SSL/TLS, WAF, DDoS, Bot protection, API security, and performance.',
        }}
        cta={{ href: '/tracks/application-services', label: { vi: 'Bắt đầu với Application Services', en: 'Start Application Services' } }}
      />
      <PathCard
        title={{ vi: 'Tôi muốn build và deploy app', en: 'I want to build and deploy an app' }}
        description={{
          vi: 'Học Pages, Workers, R2, D1, KV, AI Gateway và Workers AI.',
          en: 'Learn Pages, Workers, R2, D1, KV, AI Gateway, and Workers AI.',
        }}
        cta={{ href: '/tracks/developer-platform', label: { vi: 'Bắt đầu với Developer Platform', en: 'Start Developer Platform' } }}
      />
      <PathCard
        title={{ vi: 'Tôi muốn bảo vệ users và workforce', en: 'I want to secure users and workforce' }}
        description={{
          vi: 'Khám phá Zero Trust, ZTNA, SWG, CASB, DLP, remote users và VPN replacement.',
          en: 'Explore Zero Trust, ZTNA, SWG, CASB, DLP, remote users, and VPN replacement.',
        }}
        cta={{ href: '/tracks/cloudflare-one', label: { vi: 'Bắt đầu với Cloudflare One', en: 'Start Cloudflare One' } }}
      />
    </div>
  </section>

  <section class="mt-10">
    <div class="mb-4 flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <LangText as="h2" class="text-xl font-semibold md:text-2xl" text={{ vi: 'Tình huống thực tế', en: 'Practical use cases' }} />
        <LangText
          as="p"
          class="text-muted mt-1 max-w-2xl text-sm"
          text={{
            vi: 'Năm tình huống theo ba lộ trình — Application Services, Developer Platform và Cloudflare One.',
            en: 'Five scenarios across three tracks — Application Services, Developer Platform, and Cloudflare One.',
          }}
        />
      </div>
      <a class="btn btn-secondary shrink-0" href="/use-cases">
        <LangText text={{ vi: 'Xem tất cả', en: 'Browse all' }} />
      </a>
    </div>
    <div class="grid gap-4 md:grid-cols-3">
      <PathCard
        title={{ vi: 'Application Services', en: 'Application Services' }}
        description={{
          vi: 'Bảo vệ website public và API — DNS, CDN, WAF, SSL/TLS.',
          en: 'Protect public websites and APIs — DNS, CDN, WAF, SSL/TLS.',
        }}
        cta={{ href: '/use-cases#application-services', label: { vi: '2 tình huống', en: '2 scenarios' } }}
      />
      <PathCard
        title={{ vi: 'Developer Platform', en: 'Developer Platform' }}
        description={{
          vi: 'Build và deploy app serverless — Pages, Workers, D1, KV, R2.',
          en: 'Build and deploy serverless apps — Pages, Workers, D1, KV, R2.',
        }}
        cta={{ href: '/use-cases#developer-platform', label: { vi: '1 tình huống', en: '1 scenario' } }}
      />
      <PathCard
        title={{ vi: 'Cloudflare One', en: 'Cloudflare One' }}
        description={{
          vi: 'Zero Trust cho remote users — thay VPN, SWG, Access.',
          en: 'Zero Trust for remote users — VPN replacement, SWG, Access.',
        }}
        cta={{ href: '/use-cases#cloudflare-one', label: { vi: '2 tình huống', en: '2 scenarios' } }}
      />
    </div>
  </section>

  <section class="mt-10 grid gap-6 md:grid-cols-2 md:items-start">
    <div class="card">
      <LangText as="h2" class="text-xl font-semibold md:text-2xl" text={{ vi: 'Recommended beginner path', en: 'Recommended beginner path' }} />
      <p class="text-muted mt-2 text-sm">
        <span class="lang-vi">Một lộ trình ngắn để không bị ngợp.</span>
        <span class="lang-en">A short path to avoid overwhelm.</span>
      </p>
      <div class="mt-4">
        <JourneyStepper
          steps={[
            { vi: 'Hiểu Cloudflare làm gì', en: 'Understand what Cloudflare does' },
            { vi: 'Hiểu request flow: user → Cloudflare edge → origin/app', en: 'Learn request flow: user → Cloudflare edge → origin/app' },
            { vi: 'Chọn lộ trình phù hợp', en: 'Pick your track' },
            { vi: 'Đọc một use case thực tế', en: 'Read one practical use case' },
            { vi: 'Hoàn thành beginner checklist', en: 'Complete the beginner checklist' },
            { vi: 'Làm lộ trình 7 ngày (tuần đầu)', en: 'Follow the 7-day first-week path' },
            { vi: 'Tham gia workshop hoặc thử lab', en: 'Join a workshop or try a lab' },
          ]}
        />
      </div>
      <a class="link mt-4 inline-block text-sm" href="/first-week">
        <LangText text={{ vi: 'Xem chi tiết tuần đầu →', en: 'See the full first-week plan →' }} />
      </a>
    </div>

    <div class="space-y-4">
      <CTASection
        title={{ vi: 'Bắt đầu trong 30 phút', en: 'Get started in 30 minutes' }}
        description={{
          vi: 'Đi theo Journey A: Start Here → Cloudflare 101 → Choose Your Path.',
          en: 'Follow Journey A: Start Here → Cloudflare 101 → Choose Your Path.',
        }}
        cta={{ href: '/start-here', label: { vi: 'Bắt đầu tại đây', en: 'Start here' } }}
      />
      <CTASection
        title={{ vi: 'Sẵn sàng chưa?', en: 'Ready yet?' }}
        description={{
          vi: 'Làm bài kiểm tra 12 câu — có giải thích từng đáp án để ôn lại kiến thức.',
          en: 'Take a 12-question knowledge check with explanations for every answer.',
        }}
        cta={{ href: '/quiz/beginner-readiness', label: { vi: 'Kiểm tra kiến thức', en: 'Knowledge check' } }}
      />
    </div>
  </section>
</BaseLayout>
