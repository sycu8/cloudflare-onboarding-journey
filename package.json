{
  "name": "cloudflare-learning-hub",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node scripts/copy-dist-assets.mjs",
    "preview": "astro preview",
    "test:e2e": "playwright test",
    "test:smoke": "node scripts/smoke-test.mjs",
    "test:prod": "node scripts/smoke-test.mjs https://cloudflare-starter-hub.pages.dev && node scripts/smoke-test.mjs https://onboarding.orangecloud.vn",
    "deploy": "npm run build && npx wrangler pages deploy dist --project-name=cloudflare-starter-hub --commit-dirty=true",
    "deploy:verify": "npm run test:prod",
    "assets:sync": "node scripts/sync-static-assets-r2.mjs",
    "diagrams:sync": "node scripts/scrape-ref-arch-diagrams.mjs",
    "resources:sync": "node scripts/sync-cloudflare-resources.mjs",
    "review:pr": "node scripts/review-contribution.mjs",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/mdx": "^6.0.1",
    "@astrojs/react": "^5.0.6",
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.4.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0"
  }
}
